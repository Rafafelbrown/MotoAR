# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Binary files
*.xlsx binary
*.csv binary
*.pdf binary
*.png binary
*.jpg binary
*.gif binary
*.svg binary
